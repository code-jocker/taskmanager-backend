              "raw": "{\n  \"name\": \"Mathematics Grade 10\",\n  \"code\": \"MATH10\",\n  \"description\": \"Advanced mathematics for grade 10 students\",\n  \"manager_id\": 1,\n  \"type\": \"class\",\n  \"academic_year\": \"2024-2025\",\n  \"semester\": \"1\",\n  \"max_students\": 30\n}"
            },
            "url": {
