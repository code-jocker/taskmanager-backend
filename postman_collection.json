              "raw": "{\n  \"title\": \"Algebra Assignment 1\",\n  \"description\": \"Solve the given algebraic equations\",\n  \"instructions\": \"Show all working steps clearly\",\n  \"due_date\": \"2024-02-15T23:59:59Z\",\n  \"class_id\": 1,\n  \"priority\": \"medium\",\n  \"type\": \"assignment\",\n  \"max_score\": 100,\n  \"submission_type\": \"both\",\n  \"late_submission_allowed\": true,\n  \"late_penalty_percentage\": 10\n}"
            },
            "url": {
