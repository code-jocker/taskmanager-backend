            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@testschool.rw\",\n  \"password\": \"password123\",\n  \"phone\": \"+250788123456\",\n  \"role\": \"teacher\",\n  \"employee_id\": \"EMP001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          }
