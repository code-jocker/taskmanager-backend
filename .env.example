# Option 1: Use full DATABASE_URL (Render/Heroku/Railway)
DATABASE_URL=postgresql://user:password@host/dbname

# Option 2: Individual credentials (local dev)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rwanda_task_management
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_DIALECT=postgres

# JWT
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=production

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Org code prefix
ORG_CODE_PREFIX=RW
